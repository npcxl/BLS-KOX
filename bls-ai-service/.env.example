# bls-ai-service 环境变量

NODE_ENV=development
APP_PORT=7201
APP_HOST=0.0.0.0

# JWT 密钥（与 bls-server 保持一致，用于验证前端传来的 Bearer Token）
JWT_SECRET=CHANGE_TO_A_STRONG_JWT_SECRET

# ====== AI Provider 配置 ======
# Provider 选择: ollama | deepseek | openai | qwen | custom
# Docker 默认使用内置 Ollama（qwen2.5:7b），本地开发可按需切换
AI_PROVIDER=ollama

# 模型名称
# Ollama: qwen2.5:7b / qwen2.5-coder:7b / deepseek-coder-v2:16b / llama3.1:8b
# DeepSeek: deepseek-chat / deepseek-coder
# OpenAI: gpt-4o-mini / gpt-4o / gpt-3.5-turbo
# 通义千问: qwen-turbo / qwen-plus / qwen-max
AI_MODEL=qwen2.5:7b

# API Key（Ollama 本地模式可留空或填任意占位值，云端 API 必填）
OPENAI_API_KEY=ollama

# 自定义 Base URL（兼容 OpenAI 格式的第三方 API 服务）
# Ollama 默认: http://127.0.0.1:11434/v1（Docker 内用 http://ollama:11434/v1）
# DeepSeek: https://api.deepseek.com/v1
# OpenAI: https://api.openai.com/v1
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# 不设置则自动根据 AI_PROVIDER 选择默认端点
# AI_BASE_URL=

# AI 请求超时（毫秒），默认 60 秒
AI_TIMEOUT_MS=60000

# 温度参数（0-2），越小越确定，越大越随机。建议 0.1-0.5
AI_TEMPERATURE=0.3

# ====== Redis 配置 ======
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Redis 6+ ACL 用户名（默认为空，使用 default 用户）
REDIS_USERNAME=

# Redis 密码（必填，生产环境禁止为空或弱密码）
REDIS_PASSWORD=CHANGE_TO_A_STRONG_REDIS_PASSWORD

# 关闭 Redis 后限流功能会降级放行（不安全，仅开发测试用）
REDIS_ENABLED=true

# Redis Key 前缀，避免与其他服务冲突
REDIS_KEY_PREFIX=bls-ai:

# ====== 限流配置 ======
# AI 接口默认限流（次/分钟/用户）
AI_RATE_LIMIT_PER_MINUTE=10

# SQL 生成额外限流（因为可能涉及数据库操作，限制更严格）
AI_SQL_RATE_LIMIT_PER_MINUTE=5

# ====== 安全配置 ======
# 内部服务认证密钥（健康检查、指标等内部接口）
INTERNAL_SECRET=CHANGE_TO_A_RANDOM_INTERNAL_SECRET

# SQL Guard: 是否强制启用写操作拦截（生产环境必须为 true）
# 关闭后允许 AI 生成非 SELECT 语句，极度危险！
SQL_GUARD_ENABLED=true
