# bls-java-server 环境变量配置
# 复制此文件为 .env 并修改

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=bls

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=CHANGE_ME_PLEASE_USE_A_RANDOM_STRING_AT_LEAST_32_CHARS

# API Sign
API_SIGN_SECRET=CHANGE_ME_API_SIGN_SECRET

# MinIO (optional)
MINIO_ENABLED=false
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bls-kox
