# ============================================================
# BLS-KOX Docker 部署环境变量模板
# 使用前复制为 .env.docker 并填入真实值：
#   cp .env.docker.example .env.docker
# ============================================================

# 应用配置
APP_PORT=6001

# 数据库配置
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CHANGE_TO_A_STRONG_DATABASE_PASSWORD
DB_NAME=kox
DB_CONNECTION_LIMIT=10

# JWT 配置
JWT_SECRET=CHANGE_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO 对象存储（生产环境必须修改）
MINIO_USER=CHANGE_TO_YOUR_MINIO_USER
MINIO_PASSWORD=CHANGE_TO_YOUR_MINIO_PASSWORD

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_TO_A_STRONG_REDIS_PASSWORD

# 限流配置
RATE_LIMIT_MAX=200
MAX_CONNECTIONS=20000
DB_CONNECTION_LIMIT=20
DB_QUEUE_LIMIT=100

# CORS 白名单（生产环境必须设置）
CORS_ORIGINS=http://localhost

# API 防重放签名密钥（生产时必须更新）
API_SIGN_SECRET=CHANGE_TO_A_RANDOM_HMAC_SECRET

# ====== 事件服务 (bls-event-service) ======
# 启用 event profile 时需配置：
#   EVENT_SERVICE_URL=http://bls-event-service:7101
EVENT_SERVICE_URL=
# 内部服务认证 Token（bls-server 与 event-service 共用，必填）
INTERNAL_SECRET=CHANGE_TO_A_RANDOM_INTERNAL_SECRET

# ====== AI 服务 (bls-ai-service) ======
# AI 提供商（Docker 默认使用内置 Ollama，可改为 deepseek / openai 等）
AI_PROVIDER=ollama
# AI 模型名称（与 Ollama 拉取的模型一致）
AI_MODEL=qwen2.5:7b
# AI API 密钥（Ollama 本地模式可留空或填任意值；接入云端 API 时必填）
OPENAI_API_KEY=ollama
# AI API 地址（Ollama 本地模式；切换为云端 API 时注释掉此行）
AI_BASE_URL=http://ollama:11434/v1
