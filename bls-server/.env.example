NODE_ENV=development
APP_PORT=6001
APP_NAME=bls-server

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=bls
DB_CONNECTION_LIMIT=10

JWT_SECRET=please_change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:9000

#可信代理（Nginx 前置时开启，Koa 信任 X-Forwarded-* Header）
TRUST_PROXY=false

#Redis配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=123456

#防重放攻击配置
REPLAY_ENABLED=true
#API_SIGN_SECRET=your-hmac-secret-here（签名模式需要，浏览器前端不设置）
#REPLAY_WINDOW_SECONDS=120
#REPLAY_NONCE_TTL_SECONDS=180
#REPLAY_DEFAULT_MODE=nonce
#REPLAY_PROTECTED_METHODS=POST,PUT,PATCH,DELETE