{
  "name": "bls-kox-server",
  "version": "1.0.0",
  "private": true,
  "description": "Security-first multi-tenant SaaS backend built with Koa and TypeScript.",
  "repository": {
    "type": "git",
    "url": "https://github.com/npcxl/BLS-KOX.git",
    "directory": "bls-server"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:init": "tsx src/scripts/init-db.ts",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:backup": "tsx src/scripts/backup.ts",
    "db:restore": "tsx src/scripts/restore.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@koa/cors": "~5.0.0",
    "@types/exceljs": "^0.5.3",
    "argon2": "^0.44.0",
    "dotenv": "~17.4.2",
    "exceljs": "^4.4.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "~9.0.3",
    "koa": "~3.2.1",
    "koa-body": "^8.0.0",
    "koa-bodyparser": "~4.4.1",
    "koa-compose": "~4.1.0",
    "koa-helmet": "~9.0.0",
    "koa-router": "~14.0.0",
    "kysely": "^0.29.2",
    "minio": "^8.0.7",
    "mysql2": "~3.22.5",
    "prom-client": "^15.1.3",
    "ws": "^8.18.3",
    "zod": "~4.4.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "~9.0.10",
    "@types/koa": "~3.0.3",
    "@types/koa__cors": "^5.0.1",
    "@types/koa-bodyparser": "~4.3.13",
    "@types/koa-compose": "~3.2.9",
    "@types/koa-router": "~7.4.9",
    "@types/node": "~25.9.2",
    "@types/ws": "^8.18.1",
    "tsx": "~4.22.4",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
  }
}
