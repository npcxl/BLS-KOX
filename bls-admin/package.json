{
  "name": "Baolongshen-Admin-Template",
  "version": "1.0.0",
  "private": true,
  "description": "Baolongshen Admin Template",
  "repository": "https://gitee.com/leheya/bls-server",
  "scripts": {
    "analyze": "cross-env ANALYZE=1 max build",
    "biome": "biome check --write",
    "biome:lint": "biome lint",
    "build": "max build",
    "deploy": "cross-env CI=true max build && gh-pages -d dist",
    "dev": "cross-env UMI_ENV=dev MOCK=none PORT=9000 max dev",
    "doctor": "react-doctor .",
    "i18n-remove": "node scripts/i18n-remove.js",
    "lint": "npm run biome:lint && npm run tsc",
    "lint-staged": "lint-staged",
    "openapi": "max openapi",
    "prepare": "npx husky && max setup",
    "preview": "max preview --port 9000",
    "preview:build": "max build && max preview --port 9000",
    "record": "cross-env NODE_ENV=development UMI_ENV=test max record --scene=login",
    "simple": "node scripts/simple.js",
    "start": "cross-env UMI_ENV=dev max dev",
    "start:no-mock": "cross-env MOCK=none max dev",
    "start:pre": "cross-env UMI_ENV=pre MOCK=none max dev",
    "start:test": "cross-env UMI_ENV=test MOCK=none max dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tsc": "tsc --noEmit",
    "check": "npm run biome:lint && npm run tsc && npm run test",
    "ci": "npm run lint && npm run test && npm run build"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@ant-design/plots": "^2.6.8",
    "@ant-design/pro-components": "^3.1.12-0",
    "@ant-design/x": "^2.7.0",
    "@ant-design/x-markdown": "^2.7.0",
    "@ant-design/x-sdk": "^2.7.0",
    "@iconify/json": "^2.2.489",
    "@iconify/react": "^6.0.2",
    "@rc-component/util": "^1.11.0",
    "@tanstack/react-query": "^5.101.0",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-react": "^1.0.6",
    "antd": "^6.4.3",
    "antd-style": "^4.1.0",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dayjs": "^1.11.20",
    "highlight.js": "^11.11.1",
    "md5": "^2.3.0",
    "prosemirror-transform": "^1.12.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@ant-design/cli": "^6.4.3",
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.6",
    "@types/md5": "^2.3.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-helmet": "^6.1.11",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "@umijs/lint": "^4.6.51",
    "@umijs/max": "^4.6.57",
    "@umijs/max-plugin-openapi": "^2.0.3",
    "@umijs/request-record": "^1.1.4",
    "@vitest/coverage-v8": "^3.2.7",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "geojson": "^0.5.0",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^17.0.2",
    "react-doctor": "^0.3.0",
    "swagger-ui-dist": "^5.32.5",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.7"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "create-umi": {
    "ignoreScript": [
      "docker*",
      "functions*",
      "site",
      "generateMock"
    ],
    "ignoreDependencies": [
      "netlify*",
      "serverless"
    ],
    "ignore": [
      ".dockerignore",
      ".git",
      ".github",
      ".gitpod.yml",
      "CODE_OF_CONDUCT.md",
      "Dockerfile",
      "Dockerfile.*",
      "lambda",
      "LICENSE",
      "netlify.toml",
      "README.*.md",
      "azure-pipelines.yml",
      "docker",
      "CNAME",
      "create-umi"
    ]
  }
}
