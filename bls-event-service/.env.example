# bls-event-service 环境变量
NODE_ENV=development
APP_PORT=7101
APP_HOST=0.0.0.0

# 数据库（与主后端共享同一 MySQL）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CHANGE_TO_A_STRONG_DATABASE_PASSWORD
DB_NAME=bls
DB_CONNECTION_LIMIT=5

# 内部服务认证 Token（与 bls-server 的 INTERNAL_SECRET 保持一致，必填）
INTERNAL_SECRET=CHANGE_TO_A_RANDOM_INTERNAL_SECRET
